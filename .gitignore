node_modules/
dist/
.shadow/
*.db
*.db-journal
.env
.DS_Store
.pi/proposal-queue.json
.pi/flows/agents/
.pi/flows/results/
.pi/dashboard/kb/
# Stale TS compile output inside src/ directories.
# Plugins ship .tsx directly via package.json exports; .js/.d.ts artifacts
# from accidental tsc runs pollute the source tree and shadow real .tsx in
# resolvers. See change: add-ui-popover-primitive.
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
# Hand-authored Vite ambient types (?worker / ?url) — not a build artifact.
!packages/client/src/vite-env.d.ts
packages/electron/resources/server
packages/electron/resources/node
packages/electron/resources/git
packages/electron/resources/icons
packages/electron/resources/offline-packages
packages/electron/resources/bundled-extensions
packages/electron/out
packages/electron/.vite
site/.astro/
*.tsbuildinfo
.worktrees/
# Per-worktree test-harness state (ports + compose project). See change: parallelize-test-harness.
.pi-test-harness.json
# Playwright E2E outputs (tests/e2e). See change: add-playwright-e2e.
playwright-report/
test-results/
.playwright/
doc-example/

# kb knowledge base index
/.pi/dashboard/kb/index.db
