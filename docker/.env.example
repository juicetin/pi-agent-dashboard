# pi-dashboard Docker configuration.
# Copy to .env and edit:  cp .env.example .env
# All values have sensible defaults; everything here is optional.

# ── Provider API keys ──────────────────────────────────────────────────
# Seeded into ~/.pi/agent/auth.json on FIRST RUN ONLY (never overwrites an
# existing volume). Leave blank to add keys later via the dashboard UI.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Ports ──────────────────────────────────────────────────────────────
# Dashboard web UI / REST / browser WebSocket.
DASHBOARD_PORT=8000
# Pi gateway (external pi sessions connect here).
PI_GATEWAY_PORT=9999

# ── Pi gateway external access ─────────────────────────────────────────
# HOST publish interface for the gateway port:
#   0.0.0.0   -> reachable from other machines (default)
#   127.0.0.1 -> reachable only from the Docker host
PI_GATEWAY_BIND=0.0.0.0

# ── zrok tunnel ────────────────────────────────────────────────────────
# TUNNEL_ENABLED=0 passes --no-tunnel. Set ZROK_TOKEN to auto-enroll.
TUNNEL_ENABLED=1
ZROK_TOKEN=

# ── Session spawn strategy ─────────────────────────────────────────────
# headless | tmux. Seeded into config.json on first run only.
PI_SPAWN_STRATEGY=tmux

# ── Resource limits ────────────────────────────────────────────────────
# Container memory ceiling (Docker units, e.g. 2g, 4g, 8g).
MEM_LIMIT=4g

# ── Workspaces (path-identical mounts) ─────────────────────────────────
# Used by docker/up.sh. Path-separator list of host dirs to bind-mount at
# their IDENTICAL absolute paths inside the container. up.sh also exports
# this list as PI_DASHBOARD_PIN_DIRS.
#   PI_WORKSPACES=/Users/x/Project/a:/Users/x/Project/b
PI_WORKSPACES=

# First-run pin list (path-separator list). Honored by the server only when
# no pinned dirs are persisted yet. up.sh sets this from PI_WORKSPACES; set
# it directly when using compose.override.yml instead.
#   PI_DASHBOARD_PIN_DIRS=/Users/x/Project/a:/Users/x/Project/b
PI_DASHBOARD_PIN_DIRS=
