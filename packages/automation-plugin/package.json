{
  "name": "@blackbelt-technology/pi-dashboard-automation-plugin",
  "version": "0.6.0",
  "description": "Automation plugin for pi-dashboard — schedule-triggered background agent runs with a triage inbox (Codex-Automations-style), built on the dashboard shell slots.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackBeltTechnology/pi-agent-dashboard",
    "directory": "packages/automation-plugin"
  },
  "exports": {
    ".": {
      "types": "./src/client/index.tsx",
      "default": "./src/client/index.tsx"
    },
    "./client": {
      "types": "./src/client/index.tsx",
      "default": "./src/client/index.tsx"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    }
  },
  "files": [
    "src/"
  ],
  "pi-dashboard-plugin": {
    "id": "automation",
    "displayName": "Automations",
    "i18nCatalog": "catalog",
    "priority": 100,
    "client": "./src/client/index.tsx",
    "server": "./src/server/index.ts",
    "bridge": "./src/bridge/index.ts",
    "configSchema": "./src/configSchema.json",
    "claims": [
      {
        "slot": "sidebar-folder-section",
        "component": "FolderAutomationSection"
      },
      {
        "slot": "shell-overlay-route",
        "component": "AutomationBoard",
        "path": "/folder/:encodedCwd/automations",
        "depth": 1
      },
      {
        "slot": "shell-overlay-route",
        "component": "AutomationRunMonitor",
        "path": "/automation/run/:sid",
        "sessionParam": "sid",
        "depth": 2,
        "parentPath": "/folder/:encodedCwd/automations"
      },
      {
        "slot": "session-card-badge",
        "component": "AutomationBadge",
        "predicate": "isAutomationRun"
      },
      {
        "slot": "settings-section",
        "component": "AutomationSettings",
        "tab": "general"
      }
    ]
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@blackbelt-technology/dashboard-plugin-runtime": "^0.6.0",
    "@blackbelt-technology/pi-dashboard-client-utils": "^0.6.0",
    "@blackbelt-technology/pi-dashboard-shared": "^0.6.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
