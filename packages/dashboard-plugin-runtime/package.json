{
  "name": "@blackbelt-technology/dashboard-plugin-runtime",
  "version": "0.4.5",
  "description": "Plugin loader, slot registry, slot consumers, and context API for pi-dashboard",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackBeltTechnology/pi-agent-dashboard",
    "directory": "packages/dashboard-plugin-runtime"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./context": {
      "types": "./src/plugin-context.tsx",
      "default": "./src/plugin-context.tsx"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    },
    "./vite-plugin": {
      "types": "./src/vite-plugin/index.ts",
      "default": "./src/vite-plugin/index.ts"
    }
  },
  "files": [
    "src/"
  ],
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@blackbelt-technology/pi-dashboard-shared": "^0.4.5"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "@types/react": "^19.0.0",
    "vite": "^6.0.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@vitejs/plugin-react": "^4.3.4",
    "ajv": "^8.17.1"
  }
}
