{
  "name": "@blackbelt-technology/pi-dashboard-plugin-skill",
  "version": "0.6.1",
  "description": "Pi skill that scaffolds new dashboard plugins or augments existing pi-extension projects with dashboard plugin contributions",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackBeltTechnology/pi-agent-dashboard",
    "directory": "packages/dashboard-plugin-skill"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi-skill",
    "pi-dashboard",
    "pi-dashboard-plugin"
  ],
  "pi": {
    "skills": [
      ".pi/skills/dashboard-plugin-scaffold"
    ]
  },
  "bin": {
    "pi-dashboard-plugin-scaffold": "src/bin/scaffold.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./render": {
      "types": "./src/render.ts",
      "default": "./src/render.ts"
    }
  },
  "files": [
    "src/",
    ".pi/skills/"
  ],
  "scripts": {
    "test": "vitest run"
  },
  "dependencies": {
    "@blackbelt-technology/pi-dashboard-shared": "^0.6.1"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  }
}
