{
  "name": "{{ packageName }}",
  "version": "0.1.0",
  "description": "{{ displayName }} — pi-dashboard plugin",
  "type": "module",
  "private": false,
  "exports": {{ exportsBlock }},
  "files": [
    "src/",
    "configSchema.json"
  ],
  "scripts": {
    "test": "vitest run"
  },
  "dependencies": {
    "@blackbelt-technology/dashboard-plugin-runtime": "{{ runtimeVersionRange }}",
    "@blackbelt-technology/pi-dashboard-shared": "{{ sharedVersionRange }}"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "@types/react": "^19.0.0",
    "vitest": "^2.1.8"
  },
  "pi-dashboard-plugin": {
    "id": "{{ id }}",
    "displayName": "{{ displayName }}",
    "priority": {{ priority }},
    "requiredApi": "{{ requiredApi }}",
    "client": "./src/client.tsx"{{ serverManifestField }}{{ bridgeManifestField }}{{ configSchemaManifestField }},
    "claims": {{ claimsBlock }}
  }
}
