FROM node:22-bookworm-slim

# Install build tools for native modules + Linux packaging
RUN apt-get update -o Acquire::AllowInsecureRepositories=true && \
    apt-get install -y --allow-unauthenticated --no-install-recommends \
    dpkg \
    fakeroot \
    libarchive-tools \
    python3 \
    make \
    g++ \
    curl \
    ca-certificates \
    xz-utils \
    bzip2 \
    wget \
    unzip \
    zip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy only what's needed (not the full project with all deps)
COPY . .

# Install ALL dependencies (including devDependencies for electron-forge)
# --ignore-scripts: skip phantomjs-prebuilt install (no arm64 binary, not needed for build)
# Then rebuild only the native modules we actually need (node-pty).
RUN npm install --ignore-scripts || (cat /root/.npm/_logs/*debug*.log | tail -50 && exit 1)

# Run postinstall for packages that actually need it (electron binary download, node-pty native build)
RUN npm rebuild node-pty 2>&1 | tail -10
RUN cd packages/electron/node_modules/electron && node install.js 2>&1 | tail -5

# Verify electron-forge is available
RUN ls node_modules/@electron-forge/cli/package.json && echo "forge: OK" || echo "forge: MISSING"

# Build web client
RUN npm run build 2>&1 | tail -5

# Entry point: receives platform args
ENTRYPOINT ["bash", "packages/electron/scripts/docker-make.sh"]
