{
  "name": "@blackbelt-technology/pi-dashboard-flows-anthropic-bridge-plugin",
  "version": "0.6.0",
  "description": "pi-flows-aware bridge: forwards @pi/anthropic-messages into every spawned flow agent. Defers activation until both peers are present; status surfaced to dashboard UI.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackBeltTechnology/pi-agent-dashboard",
    "directory": "packages/flows-anthropic-bridge-plugin"
  },
  "exports": {
    ".": {
      "types": "./src/client.tsx",
      "default": "./src/client.tsx"
    },
    "./client": {
      "types": "./src/client.tsx",
      "default": "./src/client.tsx"
    },
    "./bridge": {
      "types": "./src/bridge/index.ts",
      "default": "./src/bridge/index.ts"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    },
    "./peer-probe": {
      "types": "./src/peer-probe.ts",
      "default": "./src/peer-probe.ts"
    }
  },
  "files": [
    "src/",
    "configSchema.json"
  ],
  "scripts": {
    "test": "vitest run"
  },
  "pi-dashboard-plugin": {
    "id": "flows-anthropic-bridge",
    "displayName": "Anthropic Messages Bridge",
    "i18nCatalog": "catalog",
    "priority": 500,
    "client": "./src/client.tsx",
    "server": "./src/server/index.ts",
    "bridge": "./src/bridge/index.ts",
    "configSchema": "./configSchema.json",
    "claims": [
      {
        "slot": "settings-section",
        "component": "FlowsAnthropicBridgeSettings",
        "tab": "general"
      }
    ]
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@blackbelt-technology/pi-dashboard-shared": "^0.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
