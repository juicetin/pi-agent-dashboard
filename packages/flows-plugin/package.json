{
  "name": "@blackbelt-technology/pi-dashboard-flows-plugin",
  "version": "0.6.0",
  "description": "Flow rendering plugin for pi-dashboard — pi-flows event reaction (FlowDashboard, FlowAgentCard, FlowArchitect, etc.)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackBeltTechnology/pi-agent-dashboard",
    "directory": "packages/flows-plugin"
  },
  "exports": {
    ".": {
      "types": "./src/client/index.tsx",
      "default": "./src/client/index.tsx"
    },
    "./client": {
      "types": "./src/client/index.tsx",
      "default": "./src/client/index.tsx"
    },
    "./reducer": {
      "types": "./src/reducer.ts",
      "default": "./src/reducer.ts"
    }
  },
  "files": [
    "src/"
  ],
  "pi-dashboard-plugin": {
    "id": "flows",
    "displayName": "Flows",
    "i18nCatalog": "catalog",
    "priority": 100,
    "configSchema": "./src/configSchema.json",
    "client": "./src/client/index.tsx",
    "server": "./src/server/index.ts",
    "bridge": "./src/bridge/index.ts",
    "claims": [
      {
        "slot": "session-card-flows",
        "component": "SessionFlowActionsClaim",
        "shouldRender": "shouldRenderFlowsSubcard"
      },
      {
        "slot": "content-header-sticky",
        "component": "FlowDashboardClaim"
      },
      {
        "slot": "content-view",
        "component": "FlowYamlPreviewClaim",
        "predicate": "isFlowYamlPreviewActive"
      },
      {
        "slot": "tool-renderer",
        "component": "FlowWriteToolRenderer",
        "toolName": "flow_write"
      },
      {
        "slot": "tool-renderer",
        "component": "FlowAgentsToolRenderer",
        "toolName": "flow_agents"
      },
      {
        "slot": "settings-section",
        "component": "FlowsSettings",
        "tab": "general"
      },
      {
        "slot": "automation-action-editor",
        "component": "FlowInputWiringClaim",
        "config": {
          "actionId": "flows.run"
        }
      }
    ]
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "//deps-rationale": "client-utils retained for hooks (useMobile, useZoomPan) and Phase-2 extension-ui slot consumers (AgentMetricSlot, BreadcrumbSlot, GateSlot, aggregateGateState helper). All UI primitive components (AgentCardShell, MarkdownContent, ConfirmDialog, DialogPortal, SearchableSelectDialog, ZoomControls, format-tokens, format-duration) flow through the UI primitive registry per add-plugin-ui-primitive-registry.",
  "dependencies": {
    "@blackbelt-technology/dashboard-plugin-runtime": "^0.6.0",
    "@blackbelt-technology/pi-dashboard-client-utils": "^0.6.0",
    "@blackbelt-technology/pi-dashboard-shared": "^0.6.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
