{
  "name": "@blackbelt-technology/pi-dashboard-goal-plugin",
  "version": "0.6.0",
  "description": "Goal-driven autonomous continuation plugin for pi-dashboard — surfaces the @ricoyudog/pi-goal-hermes judge loop as a live session-card chip plus set/pause/resume/clear controls.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackBeltTechnology/pi-agent-dashboard",
    "directory": "packages/goal-plugin"
  },
  "exports": {
    ".": {
      "types": "./src/client/index.tsx",
      "default": "./src/client/index.tsx"
    },
    "./client": {
      "types": "./src/client/index.tsx",
      "default": "./src/client/index.tsx"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    },
    "./bridge": {
      "types": "./src/bridge/index.ts",
      "default": "./src/bridge/index.ts"
    }
  },
  "files": [
    "src/"
  ],
  "pi-dashboard-plugin": {
    "id": "goal",
    "displayName": "Goal",
    "i18nCatalog": "catalog",
    "priority": 100,
    "client": "./src/client/index.tsx",
    "server": "./src/server/index.ts",
    "bridge": "./src/bridge/index.ts",
    "configSchema": "./src/configSchema.json",
    "claims": [
      {
        "slot": "session-card-badge",
        "component": "GoalChip",
        "predicate": "hasGoal"
      },
      {
        "slot": "session-card-action-bar",
        "component": "GoalControl"
      },
      {
        "slot": "sidebar-folder-section",
        "component": "FolderGoalsSection"
      },
      {
        "slot": "shell-overlay-route",
        "component": "GoalsBoardClaim",
        "path": "/folder/:encodedCwd/goals"
      },
      {
        "slot": "shell-overlay-route",
        "component": "GoalDetailClaim",
        "path": "/folder/:encodedCwd/goals/:goalId"
      },
      {
        "slot": "settings-section",
        "component": "GoalPluginSettings",
        "tab": "general"
      }
    ],
    "requires": {
      "piExtensions": [
        "@ricoyudog/pi-goal-hermes"
      ]
    }
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "wouter": ">=3.0.0"
  },
  "dependencies": {
    "@blackbelt-technology/dashboard-plugin-runtime": "^0.6.0",
    "@blackbelt-technology/pi-dashboard-shared": "^0.6.0",
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "wouter": "^3.9.0"
  }
}
