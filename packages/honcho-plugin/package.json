{
  "name": "@blackbelt-technology/pi-dashboard-honcho-plugin",
  "version": "0.5.0",
  "description": "Honcho persistent-memory plugin for pi-dashboard — settings panel, per-card actions, self-host docker lifecycle, aggregate model listing.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackBeltTechnology/pi-agent-dashboard",
    "directory": "packages/honcho-plugin"
  },
  "exports": {
    ".": {
      "types": "./src/client/index.tsx",
      "default": "./src/client/index.tsx"
    },
    "./client": {
      "types": "./src/client/index.tsx",
      "default": "./src/client/index.tsx"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    }
  },
  "files": [
    "src/"
  ],
  "pi-dashboard-plugin": {
    "id": "honcho",
    "displayName": "Honcho Memory",
    "priority": 100,
    "client": "./src/client/index.tsx",
    "server": "./src/server/index.ts",
    "configSchema": "./src/configSchema.json",
    "claims": [
      {
        "slot": "settings-section",
        "component": "HonchoSettings",
        "tab": "general"
      },
      {
        "slot": "session-card-badge",
        "component": "HonchoBadge"
      },
      {
        "slot": "session-card-action-bar",
        "component": "HonchoCardActions"
      },
      {
        "slot": "anchored-popover",
        "component": "HonchoMapPopover"
      }
    ]
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@blackbelt-technology/dashboard-plugin-runtime": "^0.5.0",
    "@blackbelt-technology/pi-dashboard-shared": "^0.5.0",
    "@honcho-ai/sdk": "^1.0.0",
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
