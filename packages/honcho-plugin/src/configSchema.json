{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Honcho Memory plugin configuration",
  "description": "Per-plugin (global) configuration mirror of ~/.honcho/config.json. See change: honcho-dashboard-plugin.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "apiKey": { "type": "string", "description": "Honcho API key (redacted in GET /config)." },
    "peerName": { "type": "string" },
    "workspace": { "type": "string" },
    "aiPeer": { "type": "string" },
    "linkedHosts": { "type": "string", "description": "CSV of linked-host workspaces." },
    "mode": { "type": "string", "enum": ["cloud", "self-host"], "default": "cloud" },
    "hosts": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "pi": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "endpoint": { "type": "string" },
            "recallMode": { "type": "string", "enum": ["hybrid", "context", "tools"] },
            "sessionStrategy": {
              "type": "string",
              "enum": ["per-directory", "git-branch", "pi-session", "per-repo", "global"]
            },
            "sessions": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        }
      }
    },
    "selfHost": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "autoStart": { "type": "boolean", "default": true },
        "apiPort": { "type": "integer", "default": 8765 },
        "dbPort": { "type": "integer", "default": 5455 },
        "migrationsApplied": { "type": "boolean", "default": false },
        "storageBackend": {
          "type": "string",
          "enum": ["host-directory", "docker-volume", "loop-image"],
          "default": "host-directory"
        },
        "llm": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "source": {
              "type": "string",
              "enum": ["pi-model-proxy", "anthropic", "openai", "gemini", "openai-compatible"]
            },
            "model": { "type": "string" },
            "apiKey": { "type": "string" },
            "baseUrl": { "type": "string" },
            "embeddingModel": { "type": "string" },
            "summaryModel": { "type": "string" },
            "deriverModel": { "type": "string" }
          }
        }
      }
    }
  }
}
