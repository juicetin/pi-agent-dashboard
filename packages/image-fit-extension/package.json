{
  "name": "@blackbelt-technology/pi-image-fit-extension",
  "version": "0.6.1",
  "description": "Pi extension that resizes oversize images at Read-time so they fit model byte and pixel ceilings.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackBeltTechnology/pi-agent-dashboard",
    "directory": "packages/image-fit-extension"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "image",
    "resize"
  ],
  "pi": {
    "extensions": [
      "src/extension.ts"
    ]
  },
  "files": [
    "src/",
    "!src/__tests__",
    "README.md"
  ],
  "dependencies": {
    "jimp": "^1.6.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@mariozechner/pi-coding-agent": "*"
  },
