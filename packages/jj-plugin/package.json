{
  "name": "@blackbelt-technology/pi-dashboard-jj-plugin",
  "version": "0.0.0-test-darwin-x64.1",
  "description": "Jujutsu (jj) workspace plugin for pi-dashboard — adds session-card badge, action bar, sidebar workspace list, and the jj-workspace + jj-workspace-fold-back skills.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackBeltTechnology/pi-agent-dashboard",
    "directory": "packages/jj-plugin"
  },
  "exports": {
    ".": {
      "types": "./src/client/index.tsx",
      "default": "./src/client/index.tsx"
    },
    "./client": {
      "types": "./src/client/index.tsx",
      "default": "./src/client/index.tsx"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    }
  },
  "files": [
    "src/"
  ],
  "pi-dashboard-plugin": {
    "id": "jj",
    "displayName": "Jujutsu Workspaces",
    "priority": 100,
    "client": "./src/client/index.tsx",
    "server": "./src/server/index.ts",
    "configSchema": "./src/configSchema.json",
    "claims": [
      {
        "slot": "session-card-badge",
        "component": "JjWorkspaceBadge",
        "predicate": "isInJjWorkspace"
      },
      {
        "slot": "session-card-action-bar",
        "component": "JjActionBar",
        "predicate": "isInJjRepo"
      },
      {
        "slot": "session-card-action-bar",
        "component": "JjInitAffordance",
        "predicate": "isInGitRepoButNotJj"
      },
      {
        "slot": "sidebar-folder-section",
        "component": "JjWorkspaceList"
      },
      {
        "slot": "command-route",
        "component": "JjWorkspaceView",
        "command": "/jj"
      },
      {
        "slot": "settings-section",
        "component": "JjPluginSettings",
        "tab": "general"
      }
    ]
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@blackbelt-technology/dashboard-plugin-runtime": "^0.0.0-test-darwin-x64.1",
    "@blackbelt-technology/pi-dashboard-shared": "^0.0.0-test-darwin-x64.1",
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
