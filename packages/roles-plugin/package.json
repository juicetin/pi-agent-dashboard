{
  "name": "@blackbelt-technology/pi-dashboard-roles-plugin",
  "version": "0.6.0",
  "description": "Bundled built-in plugin — ships first-party dashboard contributions (e.g. roles settings UI) so they're replaceable/augmentable by third-party plugins via the same slot system.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackBeltTechnology/pi-agent-dashboard",
    "directory": "packages/roles-plugin"
  },
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "default": "./src/index.tsx"
    },
    "./client": {
      "types": "./src/index.tsx",
      "default": "./src/index.tsx"
    }
  },
  "files": [
    "src/"
  ],
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@blackbelt-technology/dashboard-plugin-runtime": "^0.6.0",
    "@blackbelt-technology/pi-dashboard-shared": "^0.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0"
  },
  "pi-dashboard-plugin": {
    "id": "roles",
    "displayName": "Roles",
    "i18nCatalog": "catalog",
    "priority": 100,
    "client": "./src/index.tsx",
    "claims": [
      {
        "slot": "settings-section",
        "component": "BuiltInRolesSettings",
        "tab": "general"
      }
    ]
  }
}
