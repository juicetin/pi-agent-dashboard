{
  "name": "@blackbelt-technology/pi-dashboard-subagents-plugin",
  "version": "0.5.4",
  "description": "Subagent inspector plugin for pi-dashboard — SubagentDetailView, SubagentPopoutPage, timeline-entry types. Consumes the wire contract emitted by pi-dashboard-subagents.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackBeltTechnology/pi-agent-dashboard",
    "directory": "packages/subagents-plugin"
  },
  "exports": {
    ".": {
      "types": "./src/client/index.tsx",
      "default": "./src/client/index.tsx"
    },
    "./client": {
      "types": "./src/client/index.tsx",
      "default": "./src/client/index.tsx"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    }
  },
  "files": [
    "src/"
  ],
  "pi-dashboard-plugin": {
    "id": "subagents",
    "displayName": "Subagent Inspector",
    "priority": 100,
    "targetPackage": "@blackbelt-technology/pi-dashboard-subagents",
    "client": "./src/client/index.tsx",
    "server": "./src/server/index.ts",
    "configSchema": "./src/configSchema.json",
    "claims": [
      {
        "slot": "settings-section",
        "component": "SubagentsSettings",
        "tab": "general"
      },
      {
        "slot": "shell-overlay-route",
        "component": "SubagentPopoutClaim",
        "path": "/session/:sessionId/subagent/:agentId",
        "sessionParam": "sessionId"
      }
    ],
    "requires": {
      "piExtensions": [
        "@blackbelt-technology/pi-dashboard-subagents"
      ]
    },
    "dependsOn": [
      "roles"
    ]
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@blackbelt-technology/dashboard-plugin-runtime": "^0.5.4",
    "@blackbelt-technology/pi-dashboard-client-utils": "^0.5.4",
    "@blackbelt-technology/pi-dashboard-shared": "^0.5.4",
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "vitest": "^4.0.0"
  }
}
