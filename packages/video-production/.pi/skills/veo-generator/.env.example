# veo-generator API key file.
#
# Copy this to ".env" in ONE of these places (nearest to the project wins):
#   1. Projektek/<Project>/.env                  <- per-project key (preferred)
#   2. Projektek/<Project>/video_production/.env <- per-project key
#   3. this skill folder /.env                   <- global fallback for all projects
#
# Resolution order overall:
#   --api-key flag  >  VEO_API_KEY env  >  GEMINI_API_KEY env  >  project .env  >  skill .env
#
# Accepted key names (first non-empty wins): VEO_API_KEY, GEMINI_API_KEY, GOOGLE_API_KEY.
# Get a key from Google AI Studio: https://aistudio.google.com/apikey

VEO_API_KEY=your-google-ai-studio-key-here
# GEMINI_API_KEY=...   # used by the storyboard (nano-banana) step too
