#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  identity:
    hostname: qa-ubuntu
    username: qa
    # Password: "qa" (SHA-512 crypt).
    # Regenerate with: openssl passwd -6 qa
    password: "$6$qasalt123$l0kJUY7NELAwLRkhV5xnDQaYcuesbKc/HPSj7l3nYospJGY4UL526HwbvREhqeWTdsi4Jk.L8IqEH/eabm4Em0"
  ssh:
    install-server: true
    allow-pw: true
    authorized-keys:
      # Replace with your qa_vm_key.pub content
      - "ssh-ed25519 REPLACE_WITH_YOUR_PUBLIC_KEY qa@vm"
  storage:
    layout:
      name: lvm
  packages:
    - openssh-server
    - curl
    - ca-certificates
  late-commands:
    # Enable password-less sudo for qa user
    - echo 'qa ALL=(ALL) NOPASSWD:ALL' > /target/etc/sudoers.d/qa
    - chmod 440 /target/etc/sudoers.d/qa
  user-data:
    disable_root: true
