---
export interface Props {
  class?: string;
  compact?: boolean;
}
const { class: cls = "", compact = false } = Astro.props;
---

<svg
  viewBox="0 0 720 220"
  class:list={["w-full h-auto", cls]}
  role="img"
  aria-labelledby="arch-title arch-desc"
  xmlns="http://www.w3.org/2000/svg"
>
  <title id="arch-title">Pi-dashboard architecture</title>
  <desc id="arch-desc">
    Three components connected by WebSockets: the bridge extension inside each pi
    session, the dashboard server that aggregates events, and the browser client.
  </desc>

  <defs>
    <linearGradient id="node" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="rgb(var(--pi-accent))" stop-opacity="0.35" />
      <stop offset="100%" stop-color="rgb(var(--pi-accent2))" stop-opacity="0.15" />
    </linearGradient>
    <linearGradient id="line" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="rgb(var(--pi-accent))" stop-opacity="0.1" />
      <stop offset="50%" stop-color="rgb(var(--pi-accent))" stop-opacity="0.9" />
      <stop offset="100%" stop-color="rgb(var(--pi-accent2))" stop-opacity="0.1" />
    </linearGradient>
  </defs>

  {/* Nodes */}
  <g>
    <rect x="20" y="60" width="180" height="100" rx="16" fill="url(#node)" stroke="rgb(var(--pi-accent))" stroke-opacity="0.4" />
    <text x="110" y="110" text-anchor="middle" fill="rgb(var(--pi-fg))" font-family="Inter, sans-serif" font-weight="600" font-size="16">Bridge</text>
    <text x="110" y="130" text-anchor="middle" fill="rgb(var(--pi-muted))" font-family="Inter, sans-serif" font-size="12">inside every pi session</text>

    <rect x="270" y="60" width="180" height="100" rx="16" fill="url(#node)" stroke="rgb(var(--pi-accent))" stroke-opacity="0.4" />
    <text x="360" y="110" text-anchor="middle" fill="rgb(var(--pi-fg))" font-family="Inter, sans-serif" font-weight="600" font-size="16">Server</text>
    <text x="360" y="130" text-anchor="middle" fill="rgb(var(--pi-muted))" font-family="Inter, sans-serif" font-size="12">in-memory + JSON</text>

    <rect x="520" y="60" width="180" height="100" rx="16" fill="url(#node)" stroke="rgb(var(--pi-accent))" stroke-opacity="0.4" />
    <text x="610" y="110" text-anchor="middle" fill="rgb(var(--pi-fg))" font-family="Inter, sans-serif" font-weight="600" font-size="16">Browser</text>
    <text x="610" y="130" text-anchor="middle" fill="rgb(var(--pi-muted))" font-family="Inter, sans-serif" font-size="12">desktop · mobile · TV</text>
  </g>

  {/* Animated dotted connectors */}
  <g stroke="url(#line)" stroke-width="2" fill="none" stroke-dasharray="4 6">
    <line x1="200" y1="110" x2="270" y2="110" class="animate-pi-dash" />
    <line x1="450" y1="110" x2="520" y2="110" class="animate-pi-dash" />
  </g>

  {/* Labels */}
  <text x="235" y="100" text-anchor="middle" fill="rgb(var(--pi-accent))" font-family="JetBrains Mono, monospace" font-size="10">WS</text>
  <text x="485" y="100" text-anchor="middle" fill="rgb(var(--pi-accent))" font-family="JetBrains Mono, monospace" font-size="10">WS</text>
</svg>
