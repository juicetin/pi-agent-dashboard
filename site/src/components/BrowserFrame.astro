---
export interface Props {
  url?: string;
  class?: string;
  /** Inner class applied to the content area (e.g. aspect ratio). */
  bodyClass?: string;
}
const {
  url = "pi-dashboard.dev",
  class: cls = "",
  bodyClass = "aspect-[16/10]",
} = Astro.props;
---

<div
  class:list={[
    "pi-gradient-border rounded-xl overflow-hidden shadow-pi-glow bg-pi-surface/80 backdrop-blur",
    cls,
  ]}
>
  <div
    class="flex items-center gap-2 h-9 px-4 border-b border-pi-border/60 bg-pi-surface/90"
  >
    <div class="flex items-center gap-1.5">
      <span class="h-2.5 w-2.5 rounded-full bg-red-400/80"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-amber-400/80"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-emerald-400/80"></span>
    </div>
    <div
      class="flex-1 mx-4 text-center text-xs text-pi-muted font-mono truncate"
    >
      {url}
    </div>
    <div class="h-3 w-12"></div>
  </div>
  <div class:list={["relative bg-pi-bg", bodyClass]}>
    <slot />
  </div>
</div>
