---
import { Code } from "astro:components";
export interface Props {
  code: string;
  lang?: string;
  filename?: string;
}
const { code, lang = "bash", filename } = Astro.props;
---

<div
  class="pi-gradient-border rounded-lg overflow-hidden bg-pi-bg/80 backdrop-blur-sm"
>
  <div class="flex items-center justify-between h-9 px-3 border-b border-pi-border/60 text-xs font-mono text-pi-muted bg-pi-surface/60">
    <span>{filename ?? lang}</span>
    <button
      type="button"
      data-copy={code}
      class="rounded-md border border-pi-border/80 px-2 py-0.5 text-[11px] text-pi-muted hover:text-pi-fg hover:border-pi-accent/60 transition-colors"
    >
      Copy
    </button>
  </div>
  <div class="overflow-x-auto text-sm leading-relaxed pi-shiki-dual">
    <Code
      code={code}
      lang={lang as any}
      themes={{ light: "github-light", dark: "github-dark-dimmed" }}
      wrap={false}
    />
  </div>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>("button[data-copy]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.getAttribute("data-copy") ?? "";
      try {
        await navigator.clipboard.writeText(text);
        const original = btn.textContent;
        btn.textContent = "Copied!";
        setTimeout(() => (btn.textContent = original), 1200);
      } catch {
        btn.textContent = "Press ⌘C";
      }
    });
  });
</script>
