---
import {
  fetchLatestRelease,
  formatBytes,
  FALLBACK_RELEASES_URL,
} from "~/lib/github-release";

const release = await fetchLatestRelease();
const publishedLabel = release
  ? new Date(release.publishedAt).toLocaleDateString(undefined, {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  : null;

const icons: Record<"macos" | "linux" | "windows", string> = {
  macos:
    '<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16.4 12.5c0-2.3 1.9-3.4 2-3.5-1.1-1.6-2.8-1.8-3.4-1.9-1.4-.1-2.8.9-3.5.9-.7 0-1.9-.8-3.1-.8-1.6 0-3.1.9-3.9 2.4-1.7 2.9-.4 7.1 1.2 9.5.8 1.2 1.8 2.5 3 2.4 1.2-.1 1.7-.8 3.1-.8 1.5 0 1.9.8 3.2.8 1.3 0 2.2-1.2 3-2.4.9-1.4 1.3-2.7 1.3-2.8-.1 0-2.5-1-2.6-3.8zM14.1 5.3c.7-.8 1.1-2 1-3.2-1 .1-2.2.7-2.9 1.5-.6.7-1.2 1.9-1 3 1.1.1 2.2-.5 2.9-1.3z"/></svg>',
  linux:
    '<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 1.4c-2 0-3.6 1.9-3.6 4.2 0 .6.1 1.1.3 1.6-.9 1-2.3 2.9-2.3 5.1 0 1.6.6 2.8 1.6 3.7-.2.5-.5 1.1-.9 1.9-.7 1.6-.5 2.8.4 3.4 1.1.8 2.3-.4 3.3.1.6.3 1.3.3 1.9.2.9-.2 1.6-1 2.3-.3.4.4 1.1.7 1.7.7 1.1 0 1.6-.8 1.3-1.7-.3-1.1.4-1.7.3-2.7 0-.4.2-1.1.7-2 .8-1.4 1.2-2.6 1.2-3.8 0-2.2-1.4-4.1-2.3-5.1.2-.5.3-1.1.3-1.6-.1-2.3-1.8-4.2-3.8-4.2zM10.3 6c.3 0 .5.4.5.9s-.2.9-.5.9-.5-.4-.5-.9.2-.9.5-.9zm3.4 0c.3 0 .5.4.5.9s-.2.9-.5.9-.5-.4-.5-.9.2-.9.5-.9z"/></svg>',
  windows:
    '<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 5.5l8-1.1v8.1H3zm0 13l8 1.1v-8H3zm9 1.3l10 1.4v-9.7H12zm0-16l10-1.4v9.7H12z"/></svg>',
};
---

<section
  id="download"
  class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-20 md:py-24"
>
  <div class="max-w-2xl mb-10" data-reveal>
    <div class="text-xs font-mono uppercase tracking-widest text-pi-accent mb-3">
      Download
    </div>
    <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-balance">
      Get the desktop app.
      <span class="pi-accent-word"> No terminal required.</span>
    </h2>
    <p class="mt-4 text-pi-muted leading-relaxed">
      Pre-built installers for macOS, Linux, and Windows. Bundles Node.js and
      auto-installs pi + OpenSpec — you don't need any prerequisites.
    </p>
  </div>

  {
    release ? (
      <div
        class="pi-gradient-border rounded-2xl bg-pi-surface/60 backdrop-blur-sm p-6 md:p-8"
        data-reveal
        style="--reveal-delay: 1"
      >
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8 pb-6 border-b border-pi-border/60">
          <div class="flex items-center gap-4">
            <div class="inline-flex items-center gap-2 rounded-full border border-pi-accent/30 bg-pi-accent/10 px-3 py-1 text-sm font-semibold text-pi-accent">
              <span class="inline-flex h-1.5 w-1.5 rounded-full bg-pi-accent animate-pi-pulse-soft" />
              Latest
            </div>
            <div>
              <div class="text-2xl md:text-3xl font-bold tracking-tight">
                {release.tagName}
              </div>
              <div class="text-sm text-pi-muted">Released {publishedLabel}</div>
            </div>
          </div>
          <div class="flex items-center gap-3 text-sm">
            <a
              href={release.url}
              target="_blank"
              rel="noopener"
              class="text-pi-muted hover:text-pi-fg transition-colors"
            >
              Release notes ↗
            </a>
            <a
              href={release.releasesUrl}
              target="_blank"
              rel="noopener"
              class="text-pi-muted hover:text-pi-fg transition-colors"
            >
              All releases ↗
            </a>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {
            release.platforms.map((p) => (
              <div
                class="rounded-xl border border-pi-border/60 bg-pi-bg/40 p-5 flex flex-col gap-3"
                data-reveal
              >
                <div class="flex items-center gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-pi-accent/10 text-pi-accent">
                    <Fragment set:html={icons[p.id]} />
                  </div>
                  <div class="font-semibold text-lg">{p.label}</div>
                </div>

                {p.primary ? (
                  <a
                    href={p.primary.url}
                    class="group inline-flex items-center justify-between rounded-lg bg-gradient-to-r from-pi-accent to-pi-accent2 px-4 py-2.5 text-sm font-semibold text-pi-bg shadow-pi-glow hover:brightness-110 transition-all"
                  >
                    <span class="truncate">
                      Download {p.items[0]?.kind ?? ""}
                    </span>
                    <span
                      class="ml-2 font-mono text-xs opacity-70 group-hover:opacity-100"
                      aria-hidden="true"
                    >
                      {formatBytes(p.primary.size)}
                    </span>
                  </a>
                ) : (
                  <div class="text-sm text-pi-muted italic">
                    No asset available
                  </div>
                )}

                {p.items.length > 1 && (
                  <details class="group">
                    <summary class="cursor-pointer text-xs font-mono text-pi-muted hover:text-pi-fg transition-colors list-none flex items-center gap-1">
                      <span class="transition-transform group-open:rotate-90">›</span>
                      Other downloads ({p.items.length - 1})
                    </summary>
                    <ul class="mt-2 space-y-1.5 text-xs">
                      {p.items.slice(1).map((it) => (
                        <li>
                          <a
                            href={it.asset.url}
                            class="flex items-center justify-between gap-3 rounded-md border border-pi-border/50 bg-pi-surface/40 px-3 py-1.5 hover:border-pi-accent/40 hover:bg-pi-surface/60 transition-colors"
                          >
                            <span class="truncate text-pi-fg/90">
                              {it.kind}
                            </span>
                            <span class="font-mono text-pi-muted">
                              {formatBytes(it.asset.size)}
                            </span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </details>
                )}
              </div>
            ))
          }
        </div>

        <p class="mt-6 text-xs text-pi-muted text-center">
          Prefer CLI install? See the
          <a href="#install" class="text-pi-accent hover:underline">
            pi package &amp; npm options below
          </a>
          .
        </p>
      </div>
    ) : (
      <div
        class="pi-gradient-border rounded-2xl bg-pi-surface/60 backdrop-blur-sm p-8 text-center"
        data-reveal
      >
        <p class="text-pi-muted mb-4">
          Couldn't fetch the latest release at build time. Head over to GitHub
          Releases for the newest installer.
        </p>
        <a
          href={FALLBACK_RELEASES_URL}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-gradient-to-r from-pi-accent to-pi-accent2 px-5 py-2.5 text-sm font-semibold text-pi-bg shadow-pi-glow hover:brightness-110 transition-all"
        >
          View all releases <span aria-hidden="true">↗</span>
        </a>
      </div>
    )
  }
</section>
