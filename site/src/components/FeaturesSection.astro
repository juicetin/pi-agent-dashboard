---
import BentoGrid from "./BentoGrid.astro";
---

<section id="features" class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 md:py-28">
  <div class="max-w-2xl mb-10 md:mb-14" data-reveal>
    <div class="text-xs font-mono uppercase tracking-widest text-pi-accent mb-3">
      Features
    </div>
    <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-balance">
      Everything your agents do,
      <span class="pi-accent-word"> now visible.</span>
    </h2>
    <p class="mt-4 text-pi-muted leading-relaxed">
      A dozen carefully-designed surfaces on top of pi's event stream — each
      one built to answer a specific question you'd otherwise have to dig
      through the terminal to find.
    </p>
  </div>

  <BentoGrid />
</section>
