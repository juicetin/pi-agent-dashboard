---
const year = new Date().getFullYear();
---

<footer
  class="mt-32 border-t border-pi-border/60 bg-pi-bg/40 backdrop-blur-sm"
>
  <div
    class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10 flex flex-col gap-6 md:flex-row md:items-center md:justify-between"
  >
    <div class="flex items-center gap-3">
      <img
        src={`${import.meta.env.BASE_URL}/app-icon.png`}
        alt="pi-dashboard"
        width="28"
        height="28"
        class="h-7 w-7 rounded-md"
      />
      <div class="text-sm text-pi-muted">
        <div class="text-pi-fg font-medium">pi-dashboard</div>
        <div>Made with ♥ by <a class="hover:text-pi-fg" href="https://blackbelt.hu" target="_blank" rel="noopener">BlackBelt Technology</a></div>
      </div>
    </div>

    <nav class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-pi-muted" aria-label="Footer">
      <a href="https://github.com/BlackBeltTechnology/pi-agent-dashboard" target="_blank" rel="noopener" class="hover:text-pi-fg">GitHub</a>
      <a href="https://www.npmjs.com/package/@blackbelt-technology/pi-dashboard" target="_blank" rel="noopener" class="hover:text-pi-fg">npm</a>
      <a href="https://github.com/BlackBeltTechnology/pi-agent-dashboard/releases" target="_blank" rel="noopener" class="hover:text-pi-fg">Releases</a>
      <a href="https://github.com/BlackBeltTechnology/pi-agent-dashboard/blob/main/LICENSE" target="_blank" rel="noopener" class="hover:text-pi-fg">MIT license</a>
    </nav>
  </div>
  <div class="border-t border-pi-border/40 py-4 text-center text-xs text-pi-muted">
    © {year} BlackBelt Technology. Not affiliated with the π project — just obsessed.
  </div>
</footer>
