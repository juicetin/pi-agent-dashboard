---
import InstallTabs from "./InstallTabs.tsx";
---

<section id="install" class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-20 md:py-28">
  <div class="max-w-2xl mb-10" data-reveal>
    <div class="text-xs font-mono uppercase tracking-widest text-pi-accent mb-3">
      Get started
    </div>
    <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-balance">
      Three ways in.
      <span class="pi-accent-word"> All easy.</span>
    </h2>
    <p class="mt-4 text-pi-muted leading-relaxed">
      Pick whichever fits your workflow. You can always switch later.
    </p>
  </div>

  <div data-reveal style="--reveal-delay: 1">
    <InstallTabs client:visible />
  </div>
</section>
