---
export interface Props {
  /** Vertical offset of the glow's center, as CSS (e.g. "20%"). */
  y?: string;
  /** Show the masked dot-grid layer (default false; the hero hides dots
   *  globally now via KrakenBrainBackdrop's scrim). */
  showDots?: boolean;
  /** Extra classes. */
  class?: string;
}
const { y = "-10%", showDots = false, class: cls = "" } = Astro.props;
---

<div
  aria-hidden="true"
  class:list={[
    "pointer-events-none absolute inset-x-0 -z-10 overflow-hidden",
    cls,
  ]}
  style={`top: 0; height: 900px;`}
>
  <div
    class="absolute left-1/2 -translate-x-1/2 h-[1200px] w-[1400px] rounded-full blur-3xl opacity-60 animate-pi-hue"
    style={`top: ${y}; background: radial-gradient(closest-side, rgb(129 140 248 / 0.35), rgb(139 92 246 / 0.15) 50%, transparent 75%);`}
  >
  </div>
  {showDots && (
    <div
      class="absolute inset-0 pi-dot-grid [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_75%)]"
    >
    </div>
  )}
</div>
