---
import BrowserFrame from "./BrowserFrame.astro";
import GlowBackdrop from "./GlowBackdrop.astro";
import HeroAnimation from "./HeroAnimation.tsx";
---

<section class="relative isolate overflow-hidden">
  <GlowBackdrop />
  <div
    class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-20 md:pt-28 pb-20 md:pb-28"
  >
    <div
      class="mx-auto max-w-3xl text-center flex flex-col items-center gap-6"
    >
      <span
        class="inline-flex items-center gap-2 rounded-full border border-pi-accent/30 bg-pi-accent/5 px-3 py-1 text-xs font-medium text-pi-accent"
      >
        <span class="inline-flex h-1.5 w-1.5 rounded-full bg-pi-accent animate-pi-pulse-soft"></span>
        pi-dashboard is open source
      </span>
      <h1
        class="text-4xl sm:text-6xl md:text-7xl font-bold tracking-tight text-balance"
      >
        Your pi agents,
        <span class="pi-accent-word"> in the browser.</span>
      </h1>
      <p class="text-base sm:text-lg text-pi-muted max-w-2xl text-balance leading-relaxed">
        A real-time, visual, mobile-friendly dashboard for every pi session you
        run. Because not everyone thinks in monospace — and your agents
        shouldn't be stuck in a terminal.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 mt-2">
        <a
          href="https://github.com/BlackBeltTechnology/pi-agent-dashboard/releases"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-gradient-to-r from-pi-accent to-pi-accent2 px-5 py-2.5 text-sm font-semibold text-pi-bg shadow-pi-glow hover:brightness-110 transition-all"
        >
          Get the app
          <span aria-hidden="true">→</span>
        </a>
        <a
          href="https://github.com/BlackBeltTechnology/pi-agent-dashboard"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 rounded-lg border border-pi-border/80 bg-pi-surface/60 px-5 py-2.5 text-sm font-semibold text-pi-fg hover:border-pi-accent/60 transition-colors"
        >
          ⭐ Star on GitHub
        </a>
      </div>
    </div>

    <div class="mt-14 md:mt-20 mx-auto max-w-5xl">
      <div class="relative animate-pi-float">
        <BrowserFrame url="pi-dashboard.dev" bodyClass="aspect-[16/10]">
          <HeroAnimation client:load />
        </BrowserFrame>
        <div
          aria-hidden="true"
          class="absolute -bottom-10 inset-x-10 h-20 bg-gradient-to-r from-pi-accent/40 via-pi-accent2/30 to-pi-accent/40 blur-3xl opacity-60 -z-10"
        >
        </div>
      </div>
    </div>
  </div>
</section>
