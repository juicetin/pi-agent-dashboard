---
/**
 * KrakenBrainBackdrop — animated canvas backdrop:
 * neon-brain core, eight undulating tentacles, indigo→violet ripple rings,
 * binary data streams. Theme-aware (reads `.dark` on <html>) and tinted
 * from the site's --pi-accent / --pi-accent2 tokens.
 *
 * Usage: drop inside any z-isolation container (e.g. <section class="isolate">)
 * before the foreground content, alongside <GlowBackdrop />.
 */
export interface Props {
  /** Vertical span of the backdrop, in CSS units (default 900px). */
  height?: string;
  /** Light-theme canvas opacity. */
  opacity?: number;
  /** Dark-theme canvas opacity (typically lower for text readability). */
  darkOpacity?: number;
  /** CSS selector for an element whose centre the brain should align with.
   *  Falls back to `centerY` if no match. */
  centerSelector?: string;
  /** Vertical centre as a 0–1 fraction of canvas height (used when no selector). */
  centerY?: number;
  /** Extra classes on the wrapper. */
  class?: string;
}
const {
  height = "900px",
  opacity = 0.32,
  darkOpacity = 0.22,
  centerSelector,
  centerY = 0.5,
  class: cls = "",
} = Astro.props;

// Astro public assets are served at BASE_URL.
const brainSrc = `${import.meta.env.BASE_URL}/kraken-brain.png`.replace(/\/{2,}/g, "/");
---

<div
  aria-hidden="true"
  class:list={[
    "kraken-backdrop pointer-events-none absolute inset-x-0 -z-20 overflow-hidden",
    cls,
  ]}
  style={`top: 0; height: ${height}; --kb-canvas-opacity: ${opacity}; --kb-canvas-opacity-dark: ${darkOpacity};`}
>
  {/* Opaque scrim: replicates the site's body background (--pi-bg + top
      radial glow) WITHOUT the dot-grid pattern, so the body's fixed dot
      grid is masked out in this section. */}
  <div class="kraken-bg-scrim absolute inset-0"></div>
  <canvas
    data-kraken-brain
    data-center-selector={centerSelector}
    data-center-y={centerY}
    class="absolute inset-0 w-full h-full"></canvas>
</div>

<style is:global>
  /* Bind canvas tokens to the host site's pi tokens. */
  :root {
    --kb-accent-1: rgb(var(--pi-accent));
    --kb-accent-2: rgb(var(--pi-accent2));
    --kb-stream:   rgb(var(--pi-accent));
    --kb-brain-1:  rgb(var(--pi-accent) / 0.95);
    --kb-brain-2:  rgb(var(--pi-accent2) / 0.85);
    --kb-brain-3:  rgb(var(--pi-accent2) / 0.95);
    --kb-halo-1:   rgb(var(--pi-accent) / 0.18);
    --kb-halo-2:   rgb(var(--pi-accent2) / 0.10);
    --kb-glow-top: rgb(var(--pi-accent) / 0.10);
    --kb-tent-hue-min: 230;
    --kb-tent-hue-max: 265;
    --kb-tent-sat:     65;
    --kb-tent-l-outer: 65;
    --kb-tent-l-mid:   55;
    --kb-tent-l-core:  50;
    --kb-tent-a-outer: 0.10;
    --kb-tent-a-mid:   0.22;
    --kb-tent-a-core:  0.55;
    --kb-ring-blend:   source-over;
  }
  :root.dark {
    --kb-brain-1: rgb(var(--pi-accent) / 0.95);
    --kb-brain-2: rgb(var(--pi-accent) / 0.85);
    --kb-brain-3: rgb(var(--pi-accent2) / 0.92);
    --kb-halo-1:  rgb(var(--pi-accent) / 0.30);
    --kb-halo-2:  rgb(var(--pi-accent2) / 0.14);
    --kb-glow-top: rgb(var(--pi-accent) / 0.22);
    --kb-tent-hue-min: 230;
    --kb-tent-hue-max: 270;
    --kb-tent-sat:     85;
    --kb-tent-l-outer: 70;
    --kb-tent-l-mid:   72;
    --kb-tent-l-core:  85;
    --kb-tent-a-outer: 0.16;
    --kb-tent-a-mid:   0.40;
    --kb-tent-a-core:  0.78;
    --kb-ring-blend:   lighter;
  }

  /* Theme-aware canvas opacity — set as inline custom-properties on the
     backdrop element. Keeps text readable in dark mode. */
  .kraken-backdrop > canvas {
    opacity: var(--kb-canvas-opacity, 0.32);
    transition: opacity 250ms ease;
  }
  :root.dark .kraken-backdrop > canvas {
    opacity: var(--kb-canvas-opacity-dark, 0.22);
  }

  /* Scrim: body bg + top glow, no dot grid. */
  .kraken-bg-scrim {
    background:
      radial-gradient(
        ellipse 80% 50% at 50% -10%,
        rgb(var(--pi-accent) / var(--pi-glow-strength)),
        transparent 70%
      ),
      rgb(var(--pi-bg));
  }

  @media (prefers-reduced-motion: reduce) {
    .kraken-backdrop canvas { opacity: 0 !important; }
  }
</style>

<script define:vars={{ brainSrc }}>
  // Self-contained kraken brain backdrop renderer.
  // Initialises every <canvas data-kraken-brain> on the page exactly once.
  (() => {
    if (window.__krakenBackdropInstalled) return;
    window.__krakenBackdropInstalled = true;

    const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const sysDark = matchMedia("(prefers-color-scheme: dark)");

    const TENT_SEGS = 22;
    const TENTACLES = 8;
    const STREAM_PER_TENT = 5;
    const RING_COUNT = 3;

    /** Read a CSS variable from <html>; cache for one frame. */
    let cssCache = {};
    let lastThemeKey = "";
    function readVar(name, fallback) {
      if (cssCache[name] !== undefined) return cssCache[name];
      let raw = "";
      try { raw = getComputedStyle(document.documentElement).getPropertyValue(name).trim(); } catch {}
      const out = raw || fallback;
      cssCache[name] = out;
      return out;
    }
    function readNum(name, fallback) {
      const v = readVar(name, String(fallback));
      const n = parseFloat(v);
      return Number.isFinite(n) ? n : fallback;
    }
    function withAlpha(c, a) {
      c = (c || "").trim();
      const m = c.match(/^rgba?\(\s*([\d.]+)[\s,]+([\d.]+)[\s,]+([\d.]+)(?:\s*[/,]\s*[\d.]+)?\s*\)$/i);
      if (m) return `rgba(${m[1]}, ${m[2]}, ${m[3]}, ${a})`;
      return c;
    }
    function isDark() { return document.documentElement.classList.contains("dark"); }

    function palette() {
      const themeKey = isDark() ? "d" : "l";
      if (themeKey !== lastThemeKey) { cssCache = {}; lastThemeKey = themeKey; }
      const dark = isDark();
      const accent1 = readVar("--kb-accent-1", dark ? "rgb(129 140 248)" : "rgb(99 102 241)");
      const accent2 = readVar("--kb-accent-2", dark ? "rgb(139 92 246)"  : "rgb(124 58 237)");
      const stream  = readVar("--kb-stream",   accent1);
      const brain1  = readVar("--kb-brain-1",  accent1);
      const brain2  = readVar("--kb-brain-2",  accent2);
      const brain3  = readVar("--kb-brain-3",  accent2);
      const halo1   = readVar("--kb-halo-1",   dark ? "rgba(129,140,248,0.30)" : "rgba(99,102,241,0.18)");
      const halo2   = readVar("--kb-halo-2",   dark ? "rgba(139,92,246,0.14)"  : "rgba(124,58,237,0.08)");
      const glowTop = readVar("--kb-glow-top", dark ? "rgba(129,140,248,0.22)" : "rgba(99,102,241,0.10)");
      const ringBlendRaw = readVar("--kb-ring-blend", dark ? "lighter" : "source-over").toLowerCase();
      const ringBlend = (ringBlendRaw === "lighter" || ringBlendRaw === "source-over") ? ringBlendRaw : (dark ? "lighter" : "source-over");
      return {
        dark, accent1, accent2,
        rippleAccent: (a) => withAlpha(accent1, a.toFixed(3)),
        rippleAccent2: (a) => withAlpha(accent2, (a * 0.85).toFixed(3)),
        streamFill: (a) => withAlpha(stream, (a * (dark ? 0.95 : 0.70)).toFixed(3)),
        brainCmap: [brain1, brain2, brain3],
        halo: [halo1, halo2, "rgba(0,0,0,0)"],
        glowTop,
        ringBlend,
        passAlpha: [
          readNum("--kb-tent-a-outer", dark ? 0.16 : 0.10),
          readNum("--kb-tent-a-mid",   dark ? 0.40 : 0.22),
          readNum("--kb-tent-a-core",  dark ? 0.78 : 0.55),
        ],
        passLightness: [
          readNum("--kb-tent-l-outer", dark ? 70 : 65),
          readNum("--kb-tent-l-mid",   dark ? 72 : 55),
          readNum("--kb-tent-l-core",  dark ? 85 : 50),
        ],
        hueMin: readNum("--kb-tent-hue-min", 230),
        hueMax: readNum("--kb-tent-hue-max", dark ? 270 : 265),
        sat:    readNum("--kb-tent-sat",     dark ? 85 : 65),
      };
    }

    /** Convert PNG → grayscale-keyed canvas (alpha = max channel). */
    function buildKeyed(img) {
      const c = document.createElement("canvas");
      c.width = img.naturalWidth || img.width;
      c.height = img.naturalHeight || img.height;
      const g = c.getContext("2d");
      g.drawImage(img, 0, 0);
      let data;
      try { data = g.getImageData(0, 0, c.width, c.height); } catch { return null; }
      const d = data.data;
      for (let i = 0; i < d.length; i += 4) {
        const lum = Math.max(d[i], d[i+1], d[i+2]);
        d[i] = lum; d[i+1] = lum; d[i+2] = lum; d[i+3] = lum;
      }
      g.putImageData(data, 0, 0);
      return c;
    }
    function loadBrain() {
      return new Promise((resolve) => {
        const img = new Image();
        img.crossOrigin = "anonymous";
        img.onload = () => resolve(buildKeyed(img));
        img.onerror = () => resolve(null);
        img.src = brainSrc;
      });
    }

    /** Sample the keyed brain to find the silhouette edge along an angle. */
    function makeEdgeFinder(keyed) {
      const g = keyed.getContext("2d");
      const w = keyed.width, h = keyed.height;
      let data;
      try { data = g.getImageData(0, 0, w, h).data; } catch { return () => 0.5; }
      const cx0 = w / 2, cy0 = h / 2;
      const maxR = Math.min(w, h) / 2 - 1;
      return (angle) => {
        const cs = Math.cos(angle), sn = Math.sin(angle);
        let last = 0;
        for (let r = 0; r <= maxR; r += 2) {
          const x = (cx0 + cs * r) | 0;
          const y = (cy0 + sn * r) | 0;
          if (x < 0 || y < 0 || x >= w || y >= h) break;
          if (data[(y * w + x) * 4 + 3] > 30) last = r;
        }
        return last / maxR;
      };
    }

    function init(canvas) {
      if (canvas.__krakenInit) return;
      canvas.__krakenInit = true;

      const ctx = canvas.getContext("2d", { alpha: true });
      // Adaptive device-pixel-ratio. Starts at the device DPR (capped at 1.25)
      // and drops in 0.25 steps to a 0.5 floor when the rolling FPS average
      // falls below the target. Each downshift triggers a resize().
      const INITIAL_DPR = Math.min(window.devicePixelRatio || 1, 1.25);
      const MIN_DPR = 0.5;
      const DPR_STEP = 0.25;
      const FPS_TARGET = 30;
      const FPS_SAMPLE_FRAMES = 60;
      const DPR_COOLDOWN_MS = 3000;
      let DPR = INITIAL_DPR;
      let dprAdjustedAt = 0;
      const fpsBuf = [];
      let W = 0, H = 0, cx = 0, cy = 0, scale = 1;

      const bgLayer = document.createElement("canvas");
      const brainLayer = document.createElement("canvas");
      let keyedBrain = null;
      let findEdge = () => 0.5;

      const tentacles = Array.from({ length: TENTACLES }, (_, i) => ({
        baseAngle: (i / TENTACLES) * Math.PI * 2 + Math.random() * 0.15,
        length: 0.50 + Math.random() * 0.22,
        phase: Math.random() * Math.PI * 2,
        speed: 0.45 + Math.random() * 0.35,
        wobbleBase: 0.28 + Math.random() * 0.25,
        hueBase: 185 + Math.random() * 80,
        edgeNorm: 0.5,
      }));
      const tentBuf = tentacles.map(() => new Float32Array((TENT_SEGS + 1) * 2));

      // ---- Dashed-line geometry (computed once per resize, animated per
      //      frame via lineDashOffset). ----
      const DASH_COUNT = 22;
      const DASH_SAMPLES = 32;
      let dashPaths = [];
      let dashSampleBufs = []; // [Float32Array(DASH_SAMPLES * 2)] per dash path

      function rebuildDashPaths() {
        dashPaths = [];
        for (let i = 0; i < DASH_COUNT; i++) {
          dashPaths.push({
            x0: Math.random() < 0.5 ? -20 : W + 20,
            y0: Math.random() * H,
            x1: Math.random() < 0.5 ? -20 : W + 20,
            y1: Math.random() * H,
            cx1: W * (0.2 + Math.random() * 0.6),
            cy1: H * (0.1 + Math.random() * 0.8),
            cx2: W * (0.2 + Math.random() * 0.6),
            cy2: H * (0.1 + Math.random() * 0.8),
            dashLen: 5 + Math.random() * 6,
            gapLen:  8 + Math.random() * 10,
            width:   0.9 + Math.random() * 0.7,
            alphaJ:  0.85 + Math.random() * 0.6,
            speed:   (Math.random() < 0.5 ? -1 : 1) * (12 + Math.random() * 22),
            useAccent2: i % 3 === 0,
            phase:   Math.random() * 50,
          });
        }
        rebuildDashSamples();
      }
      function rebuildDashSamples() {
        dashSampleBufs = dashPaths.map((d) => {
          const buf = new Float32Array(DASH_SAMPLES * 2);
          for (let i = 0; i < DASH_SAMPLES; i++) {
            const t = i / (DASH_SAMPLES - 1);
            const mt = 1 - t;
            const b0 = mt * mt * mt;
            const b1 = 3 * mt * mt * t;
            const b2 = 3 * mt * t * t;
            const b3 = t * t * t;
            buf[i * 2]     = b0*d.x0 + b1*d.cx1 + b2*d.cx2 + b3*d.x1;
            buf[i * 2 + 1] = b0*d.y0 + b1*d.cy1 + b2*d.cy2 + b3*d.y1;
          }
          return buf;
        });
      }

      // ---- Spark particles: spawn when a tentacle tip enters proximity
      //      of a dashed-line bezier. ----
      const sparks = [];                  // { x, y, born, life, angles[] }
      const MAX_SPARKS = 24;
      const SPARK_COOLDOWN_S = 0.5;
      const sparkCooldown = new Map();    // "tIdx,dIdx" -> last spawn time

      function spawnSpark(x, y) {
        if (sparks.length >= MAX_SPARKS) sparks.shift();
        const N = 4 + ((Math.random() * 2) | 0);
        const base = Math.random() * Math.PI * 2;
        const angles = new Float32Array(N);
        const lengths = new Float32Array(N);
        for (let k = 0; k < N; k++) {
          angles[k]  = base + (k / N) * Math.PI * 2 + (Math.random() - 0.5) * 0.6;
          lengths[k] = 0.55 + Math.random() * 0.40;
        }
        sparks.push({
          x, y,
          born: performance.now(),
          life: 360 + Math.random() * 240,  // ms
          angles, lengths,
        });
      }

      function checkTipSparks(time) {
        if (dashSampleBufs.length === 0) return;
        const tipIdx = TENT_SEGS;
        const threshSq = (14 * scale) * (14 * scale);
        for (let ti = 0; ti < tentacles.length; ti++) {
          const buf = tentBuf[ti];
          const tipX = buf[tipIdx * 2];
          const tipY = buf[tipIdx * 2 + 1];
          for (let di = 0; di < dashSampleBufs.length; di++) {
            const samples = dashSampleBufs[di];
            let minSq = Infinity, mx = 0, my = 0;
            for (let j = 0; j < samples.length; j += 2) {
              const dx = samples[j]     - tipX;
              const dy = samples[j + 1] - tipY;
              const sq = dx * dx + dy * dy;
              if (sq < minSq) { minSq = sq; mx = samples[j]; my = samples[j + 1]; }
            }
            if (minSq < threshSq) {
              const key = ti * 1000 + di;
              const last = sparkCooldown.get(key);
              if (last == null || (time - last) > SPARK_COOLDOWN_S) {
                sparkCooldown.set(key, time);
                spawnSpark((tipX + mx) * 0.5, (tipY + my) * 0.5);
              }
            }
          }
        }
      }

      function drawSparks(now) {
        if (sparks.length === 0) return;
        const P = palette();
        ctx.save();
        ctx.globalCompositeOperation = "lighter";
        for (let i = sparks.length - 1; i >= 0; i--) {
          const s = sparks[i];
          const age = now - s.born;
          if (age > s.life) { sparks.splice(i, 1); continue; }
          const u = age / s.life;
          const fade = 1 - u;
          const radius = (4 + 16 * u) * scale;

          // Outer glow halo
          const grd = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, radius);
          grd.addColorStop(0,   withAlpha(P.accent1, (fade * 0.95).toFixed(3)));
          grd.addColorStop(0.4, withAlpha(P.accent1, (fade * 0.45).toFixed(3)));
          grd.addColorStop(1,   withAlpha(P.accent1, "0"));
          ctx.fillStyle = grd;
          ctx.beginPath(); ctx.arc(s.x, s.y, radius, 0, Math.PI * 2); ctx.fill();

          // Bright white core
          ctx.fillStyle = `rgba(255, 255, 255, ${(fade * 0.85).toFixed(3)})`;
          ctx.beginPath(); ctx.arc(s.x, s.y, 1.6 * scale, 0, Math.PI * 2); ctx.fill();

          // Crackle filaments (deterministic angles + lengths from spawn time)
          ctx.strokeStyle = `rgba(255, 255, 255, ${(fade * 0.7).toFixed(3)})`;
          ctx.lineWidth = 1 * scale;
          ctx.lineCap = "round";
          for (let k = 0; k < s.angles.length; k++) {
            const a = s.angles[k];
            const r1 = radius * 0.18;
            const r2 = radius * s.lengths[k];
            ctx.beginPath();
            ctx.moveTo(s.x + Math.cos(a) * r1, s.y + Math.sin(a) * r1);
            ctx.lineTo(s.x + Math.cos(a) * r2, s.y + Math.sin(a) * r2);
            ctx.stroke();
          }
        }
        ctx.restore();
      }

      // ---- Mouse / pointer tracking. The wrapper has pointer-events:none,
      //      so we listen on document and translate to canvas coords. ----
      let mouseX = 0, mouseY = 0;
      let smX = 0, smY = 0;            // smoothed mouse pos
      let mouseActive = false;
      let mouseLevel = 0;              // 0..1 ramp — fades the effect in/out

      function updateMouse(e, isTouch) {
        const src = isTouch ? e.touches[0] : e;
        if (!src) return;
        const r = canvas.getBoundingClientRect();
        mouseX = src.clientX - r.left;
        mouseY = src.clientY - r.top;
        mouseActive = mouseX >= 0 && mouseY >= 0 && mouseX <= W && mouseY <= H;
      }
      document.addEventListener("mousemove", (e) => updateMouse(e, false), { passive: true });
      document.addEventListener("touchmove",  (e) => updateMouse(e, true),  { passive: true });
      document.addEventListener("touchend",   () => { mouseActive = false; }, { passive: true });
      window.addEventListener("blur",        () => { mouseActive = false; });
      document.addEventListener("mouseleave", () => { mouseActive = false; });

      const streams = [];
      for (const t of tentacles) {
        for (let i = 0; i < STREAM_PER_TENT; i++) {
          streams.push({
            t,
            u: Math.random(),
            sp: 0.04 + Math.random() * 0.08,
            char: Math.random() < 0.5 ? "0" : "1",
            alpha: 0.5 + Math.random() * 0.4,
          });
        }
      }

      function buildBackground() {
        const P = palette();
        const dark = P.dark;
        bgLayer.width = Math.max(1, Math.floor(W * DPR));
        bgLayer.height = Math.max(1, Math.floor(H * DPR));
        const g = bgLayer.getContext("2d");
        g.setTransform(DPR, 0, 0, DPR, 0, 0);
        g.clearRect(0, 0, W, H); // canvas itself is transparent (the scrim div paints the base bg)

        // Subtle top radial glow (blends additively with the scrim's gradient)
        {
          const cxg = W * 0.5, cyg = -H * 0.15;
          const rg  = Math.max(W, H);
          const grd = g.createRadialGradient(cxg, cyg, rg * 0.05, cxg, cyg, rg);
          grd.addColorStop(0, P.glowTop);
          grd.addColorStop(0.7, withAlpha(P.glowTop, 0));
          grd.addColorStop(1, "rgba(0,0,0,0)");
          g.fillStyle = grd;
          g.fillRect(0, 0, W, H);
        }

        // ---- Decorative bubble rings (baked, static) ----
        // 35 hollow circles scattered across the canvas. Brighter than before.
        const bubbleAlpha = dark ? 0.28 : 0.22;
        const BUBBLE_COUNT = 35;
        g.lineWidth = 1 * scale;
        for (let i = 0; i < BUBBLE_COUNT; i++) {
          const x = Math.random() * W;
          const y = Math.random() * H;
          const r = 4 + Math.random() * 26;
          const useAccent2 = Math.random() < 0.25;
          g.strokeStyle = withAlpha(useAccent2 ? P.accent2 : P.accent1,
            (bubbleAlpha * (0.6 + Math.random() * 0.5)).toFixed(3));
          g.beginPath(); g.arc(x, y, r, 0, Math.PI * 2); g.stroke();
          // a fraction of bubbles also get a tiny filled centre dot
          if (Math.random() < 0.35) {
            g.fillStyle = withAlpha(useAccent2 ? P.accent2 : P.accent1, (bubbleAlpha * 0.5).toFixed(3));
            g.beginPath(); g.arc(x, y, 1.2 * scale, 0, Math.PI * 2); g.fill();
          }
        }

        // ---- Halo rings around the brain centre ----
        g.globalCompositeOperation = P.ringBlend;
        for (let k = 1; k <= 4; k++) {
          const r = (40 + k * 22) * scale;
          const a = 0.16 - k * 0.025;
          g.strokeStyle = withAlpha(P.accent1, a);
          g.lineWidth = 1 * scale;
          g.beginPath(); g.arc(cx, cy, r, 0, Math.PI * 2); g.stroke();
        }
        g.globalCompositeOperation = "source-over";
      }

      function buildBrain() {
        const P = palette();
        const dark = P.dark;
        const size = Math.ceil(300 * scale);
        brainLayer.width = Math.max(1, Math.floor(size * DPR));
        brainLayer.height = Math.max(1, Math.floor(size * DPR));
        const g = brainLayer.getContext("2d");
        g.setTransform(DPR, 0, 0, DPR, 0, 0);
        g.clearRect(0, 0, size, size);
        const r0 = size / 2;

        // Outer halo
        g.globalCompositeOperation = dark ? "lighter" : "source-over";
        const halo = g.createRadialGradient(r0, r0, r0 * 0.15, r0, r0, r0);
        halo.addColorStop(0, P.halo[0]);
        halo.addColorStop(0.45, P.halo[1]);
        halo.addColorStop(1, P.halo[2]);
        g.fillStyle = halo;
        g.beginPath(); g.arc(r0, r0, r0, 0, Math.PI * 2); g.fill();
        g.globalCompositeOperation = "source-over";

        if (!keyedBrain) return;

        const brainSize = size * 0.78;

        const tw = Math.max(1, Math.ceil(brainSize * DPR));
        const tmp = document.createElement("canvas");
        tmp.width = tw; tmp.height = tw;
        const tg = tmp.getContext("2d");
        tg.setTransform(DPR, 0, 0, DPR, 0, 0);
        tg.drawImage(keyedBrain, 0, 0, brainSize, brainSize);
        tg.globalCompositeOperation = "source-in";
        const grd = tg.createRadialGradient(
          brainSize/2, brainSize/2 - brainSize * 0.1, 0,
          brainSize/2, brainSize/2, brainSize/2
        );
        grd.addColorStop(0,   P.brainCmap[0]);
        grd.addColorStop(0.6, P.brainCmap[1]);
        grd.addColorStop(1,   P.brainCmap[2]);
        tg.fillStyle = grd;
        tg.fillRect(0, 0, brainSize, brainSize);
        tg.globalCompositeOperation = "source-over";

        const x = r0 - brainSize / 2;
        const y = r0 - brainSize / 2;
        if (dark) {
          g.globalCompositeOperation = "lighter";
          g.globalAlpha = 0.45;
          g.drawImage(tmp, x, y, brainSize, brainSize);
          g.globalAlpha = 0.78;
          g.drawImage(tmp, x, y, brainSize, brainSize);
          g.globalAlpha = 1;
          g.globalCompositeOperation = "source-over";
        } else {
          g.drawImage(tmp, x, y, brainSize, brainSize);
        }
      }

      function rebuildLayers() {
        if (W <= 0 || H <= 0) return;
        cssCache = {};
        buildBackground();
        buildBrain();
      }

      function computeCenter() {
        // Try a target selector first — align brain to a text element's centre.
        const sel = canvas.dataset.centerSelector;
        if (sel) {
          try {
            const target = document.querySelector(sel);
            if (target) {
              const tr = target.getBoundingClientRect();
              const cr = canvas.getBoundingClientRect();
              const yAbs = (tr.top + tr.height / 2) - cr.top;
              if (Number.isFinite(yAbs) && yAbs > 0 && yAbs < H) {
                cy = yAbs;
                return;
              }
            }
          } catch {}
        }
        const ratio = parseFloat(canvas.dataset.centerY || "0.5");
        cy = H * (Number.isFinite(ratio) ? ratio : 0.5);
      }

      function resize() {
        const r = canvas.getBoundingClientRect();
        W = Math.max(1, r.width); H = Math.max(1, r.height);
        canvas.width  = Math.floor(W * DPR);
        canvas.height = Math.floor(H * DPR);
        ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
        cx = W / 2;
        scale = Math.min(W, H) / 720;
        smX = cx; smY = H / 2;
        computeCenter();
        rebuildDashPaths();
        rebuildLayers();
      }

      function maxRForAngle(a, margin) {
        const c = Math.cos(a), s = Math.sin(a);
        let rx = Infinity, ry = Infinity;
        if (Math.abs(c) > 1e-6) rx = c > 0 ? (W - margin - cx) / c : (margin - cx) / c;
        if (Math.abs(s) > 1e-6) ry = s > 0 ? (H - margin - cy) / s : (margin - cy) / s;
        return Math.max(0, Math.min(rx, ry));
      }
      function tentBaseR(t) {
        const half = (300 * scale * 0.78) / 2;
        return Math.max(20 * scale, half * (t.edgeNorm ?? 0.5) * 0.92);
      }
      function updateTentacle(t, time, out, pullX, pullY, pullStrength) {
        const minDim = Math.min(W, H);
        const baseR = tentBaseR(t);
        const margin = 28 * scale;
        const angSwing = (t.wobbleBase) * 0.5;
        const safeR = Math.min(
          maxRForAngle(t.baseAngle, margin),
          maxRForAngle(t.baseAngle + angSwing, margin),
          maxRForAngle(t.baseAngle - angSwing, margin)
        );
        const desired = t.length * minDim;
        const len = Math.min(desired, Math.max(0, safeR - baseR));
        const pullR = Math.min(W, H) * 0.34;
        const maxPull = 75 * scale;
        for (let i = 0; i <= TENT_SEGS; i++) {
          const u = i / TENT_SEGS;
          const r = baseR + u * len;
          const wob = Math.sin(u * 6 + time * t.speed + t.phase) * t.wobbleBase * (0.15 + u * 0.85);
          const a = t.baseAngle + wob * 0.5;
          let sx = cx + Math.cos(a) * r;
          let sy = cy + Math.sin(a) * r;
          // Mouse pull: tip-weighted, distance-falloff. Anchor (u≈0) untouched.
          // Sharper tip bias: u³ means the brain anchor and middle of the
          // tentacle barely move; only the last ~third stretches noticeably.
          if (pullStrength > 0 && u > 0.05) {
            const dx = pullX - sx;
            const dy = pullY - sy;
            const dist = Math.hypot(dx, dy) + 1;
            const prox = Math.exp(-dist / pullR);          // 0..1
            const pull = prox * (u * u * u) * pullStrength * maxPull;
            sx += (dx / dist) * pull;
            sy += (dy / dist) * pull;
          }
          out[i * 2]     = sx;
          out[i * 2 + 1] = sy;
        }
      }
      function pointAt(buf, u) {
        const max = TENT_SEGS;
        const idx = u * max;
        const i = Math.min(max - 1, Math.floor(idx));
        const f = idx - i;
        const ax = buf[i * 2], ay = buf[i * 2 + 1];
        const bx = buf[(i + 1) * 2], by = buf[(i + 1) * 2 + 1];
        return [ax + (bx - ax) * f, ay + (by - ay) * f];
      }

      let last = performance.now();
      const t0 = last;

      function maybeAdjustDpr(now) {
        if (fpsBuf.length < FPS_SAMPLE_FRAMES) return;
        if (now - dprAdjustedAt < DPR_COOLDOWN_MS) return;
        let sum = 0;
        for (let i = 0; i < fpsBuf.length; i++) sum += fpsBuf[i];
        const avgDt = sum / fpsBuf.length;
        const fps = avgDt > 0 ? 1 / avgDt : 60;
        if (fps < FPS_TARGET && DPR > MIN_DPR) {
          DPR = Math.max(MIN_DPR, +(DPR - DPR_STEP).toFixed(2));
          dprAdjustedAt = now;
          fpsBuf.length = 0;
          // Optional debug breadcrumb (silent in prod):
          // console.debug(`[kraken] FPS ${fps.toFixed(1)} → DPR ${DPR}`);
          resize();
        }
      }

      function frame(now) {
        const rawDt = (now - last) / 1000;
        const dt = Math.min(0.05, rawDt);
        last = now;
        const time = (now - t0) / 1000;
        const P = palette();

        // Roll FPS sample.
        if (rawDt > 0 && rawDt < 0.5) {
          fpsBuf.push(rawDt);
          if (fpsBuf.length > FPS_SAMPLE_FRAMES) fpsBuf.shift();
        }
        maybeAdjustDpr(now);

        // Reset & blit
        ctx.globalCompositeOperation = "source-over";
        ctx.clearRect(0, 0, W, H);
        ctx.drawImage(bgLayer, 0, 0, W, H);

        // Ripple rings (kept tight so they don't reach the corners)
        ctx.globalCompositeOperation = P.ringBlend;
        const ringMaxR = Math.min(W, H) * 0.26;
        ctx.lineWidth = 1.2 * scale;
        for (let k = 0; k < RING_COUNT; k++) {
          const phase = ((time * 0.22) + k / RING_COUNT) % 1;
          const r = phase * ringMaxR + 50 * scale;
          const a = (1 - phase) * 0.28;
          ctx.strokeStyle = (k % 2 === 0) ? P.rippleAccent(a) : P.rippleAccent2(a);
          ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI * 2); ctx.stroke();
        }

        // ---- Smooth mouse position toward target ----
        // While mouse is over the canvas, ease toward it; otherwise fall back
        // toward the brain centre. mouseLevel is a 0..1 multiplier so the
        // pull effect fades in/out gracefully.
        const tx = mouseActive ? mouseX : cx;
        const ty = mouseActive ? mouseY : cy;
        const lerpAmt = mouseActive ? 0.10 : 0.05;
        smX += (tx - smX) * lerpAmt;
        smY += (ty - smY) * lerpAmt;
        const lvlTarget = mouseActive ? 1 : 0;
        mouseLevel += (lvlTarget - mouseLevel) * 0.07;

        // ---- Animated dashed lines (marching) ----
        ctx.save();
        ctx.lineCap = "round";
        const dashAlpha = P.dark ? 0.34 : 0.26;
        for (let i = 0; i < dashPaths.length; i++) {
          const d = dashPaths[i];
          ctx.strokeStyle = withAlpha(d.useAccent2 ? P.accent2 : P.accent1,
            (dashAlpha * d.alphaJ).toFixed(3));
          ctx.lineWidth = d.width * scale;
          ctx.setLineDash([d.dashLen * scale, d.gapLen * scale]);
          ctx.lineDashOffset = d.phase + time * d.speed;
          ctx.beginPath();
          ctx.moveTo(d.x0, d.y0);
          ctx.bezierCurveTo(d.cx1, d.cy1, d.cx2, d.cy2, d.x1, d.y1);
          ctx.stroke();
        }
        ctx.setLineDash([]);
        ctx.restore();

        // ---- Tentacles ----
        ctx.lineCap = "round";
        const widths = [12 * scale, 4 * scale, 1.2 * scale];
        for (let i = 0; i < tentacles.length; i++) {
          const t = tentacles[i];
          const buf = tentBuf[i];
          updateTentacle(t, time, buf, smX, smY, mouseLevel);
          const u = Math.max(0, Math.min(1, (t.hueBase - 185) / 80));
          const hue = (P.hueMin + u * (P.hueMax - P.hueMin) + 360) % 360;
          ctx.beginPath();
          ctx.moveTo(buf[0], buf[1]);
          for (let j = 1; j <= TENT_SEGS; j++) ctx.lineTo(buf[j * 2], buf[j * 2 + 1]);
          for (let pass = 0; pass < 3; pass++) {
            ctx.strokeStyle = `hsla(${hue}, ${P.sat}%, ${P.passLightness[pass]}%, ${P.passAlpha[pass]})`;
            ctx.lineWidth = widths[pass];
            ctx.stroke();
          }
        }

        // Streams
        ctx.font = `bold ${(10 * scale).toFixed(1)}px ui-monospace, SFMono-Regular, Menlo, monospace`;
        ctx.textAlign = "center"; ctx.textBaseline = "middle";
        for (const s of streams) {
          s.u += s.sp * dt;
          if (s.u > 1) { s.u = 0; s.char = Math.random() < 0.5 ? "0" : "1"; }
          const idx = tentacles.indexOf(s.t);
          if (idx < 0) continue;
          const p = pointAt(tentBuf[idx], s.u);
          const a = s.alpha * (0.35 + s.u * 0.65);
          ctx.fillStyle = P.streamFill(a);
          ctx.fillText(s.char, p[0], p[1]);
        }

        // Tip-vs-dashed-line collision → spark spawn + draw
        checkTipSparks(time);
        drawSparks(now);

        // Brain pulse — heartbeat (lub-DUB) layered over a slow breath.
        //   beat:   two gaussian pulses inside a 1.5s period; the second
        //           one is twice as strong as the first — same as the
        //           human cardiac "lub-dub" cadence.
        //   breath: slow sine (~3.7s period) for ambient swelling so the
        //           brain still feels alive between beats.
        // Both modulate scale AND alpha so the zoom and glow are coupled.
        const beatPeriod = 1.5;
        const bu = (time % beatPeriod) / beatPeriod;
        const lub = 0.45 * Math.exp(-0.5 * Math.pow((bu - 0.10) / 0.045, 2));
        const dub = 1.00 * Math.exp(-0.5 * Math.pow((bu - 0.28) / 0.055, 2));
        const beat = Math.min(1, lub + dub);                // 0..1
        const breath = 0.5 + 0.5 * Math.sin(time * 1.7);    // 0..1, ~3.7s period

        const zoom  = 1 + beat * 0.07 + (breath - 0.5) * 0.025; // ~+8% at peak
        const alpha = Math.min(1, 0.74 + beat * 0.20 + (breath - 0.5) * 0.06);

        const bw = (brainLayer.width  / DPR) * zoom;
        const bh = (brainLayer.height / DPR) * zoom;
        ctx.globalAlpha = alpha;
        ctx.drawImage(brainLayer, cx - bw / 2, cy - bh / 2, bw, bh);
        ctx.globalAlpha = 1;
        ctx.globalCompositeOperation = "source-over";

        if (!reduceMotion) requestAnimationFrame(frame);
      }

      // Pause when offscreen / tab hidden — saves CPU when section scrolls past.
      let running = !reduceMotion;
      const io = new IntersectionObserver((entries) => {
        const visible = entries.some(e => e.isIntersecting);
        if (visible && !running && !reduceMotion) { running = true; last = performance.now(); requestAnimationFrame(frame); }
        else if (!visible && running) { running = false; }
      }, { rootMargin: "100px" });
      io.observe(canvas);
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) running = false;
        else if (!running && !reduceMotion) { running = true; last = performance.now(); requestAnimationFrame(frame); }
      });

      // Theme follow (Astro toggles `.dark` on <html>).
      new MutationObserver(rebuildLayers)
        .observe(document.documentElement, { attributes: true, attributeFilter: ["class"] });
      sysDark.addEventListener("change", rebuildLayers);

      let resizeTo;
      window.addEventListener("resize", () => {
        clearTimeout(resizeTo);
        // On viewport change reset DPR back to the initial value so a user
        // who resizes off a low-FPS state gets full quality back.
        DPR = INITIAL_DPR;
        fpsBuf.length = 0;
        resizeTo = setTimeout(resize, 100);
      });

      // Track the centre target element — if it reflows (font load, viewport
      // resize, etc.), recompute the brain centre.
      const sel = canvas.dataset.centerSelector;
      if (sel) {
        const tryObserveTarget = () => {
          const target = document.querySelector(sel);
          if (!target) return false;
          const ro = new ResizeObserver(() => { computeCenter(); rebuildLayers(); });
          ro.observe(target);
          return true;
        };
        if (!tryObserveTarget()) {
          // Target may not exist yet at script-init time; retry briefly.
          let tries = 0;
          const iv = setInterval(() => {
            if (tryObserveTarget() || ++tries > 20) clearInterval(iv);
          }, 100);
        }
      }

      // Boot
      resize();
      loadBrain().then((keyed) => {
        if (!keyed) return;
        keyedBrain = keyed;
        findEdge = makeEdgeFinder(keyed);
        for (const t of tentacles) t.edgeNorm = findEdge(t.baseAngle);
        rebuildLayers();
      });

      if (!reduceMotion) requestAnimationFrame(frame);
    }

    function bootAll() {
      document.querySelectorAll("canvas[data-kraken-brain]").forEach(init);
    }
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", bootAll);
    } else {
      bootAll();
    }
  })();
</script>
