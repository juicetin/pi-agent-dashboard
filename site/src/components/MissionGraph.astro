---
/**
 * MissionGraph — ambient, non-figurative animated background anchored at the
 * top of the page.
 *
 * Visual encoding of the project's mission:
 *   • Left cluster  = many pi agent sessions (the terminal side)
 *   • Right spray   = any device, anywhere (desktop, mobile, TV…)
 *   • Curved dashed lines flowing left → right = events streaming through
 *     WebSockets in real time
 *   • Twinkling nodes = live sessions / connected clients
 *
 * Pure SVG + CSS — no JS, no hydration, zero bundle cost.
 * Respects prefers-reduced-motion.
 */

function seeded(seed: number) {
  let s = seed;
  return () => {
    s = (s * 9301 + 49297) % 233280;
    return s / 233280;
  };
}
const rnd = seeded(42);

// Left cluster: ~18 nodes in a fan on the left
const leftNodes = Array.from({ length: 18 }).map((_, i) => ({
  cx: 120 + rnd() * 140,
  cy: 120 + rnd() * 560,
  r: 1.2 + rnd() * 1.6,
  delay: rnd() * 4,
  dur: 3 + rnd() * 2,
  idx: i,
}));

// Right spray: ~22 nodes fanned wider
const rightNodes = Array.from({ length: 22 }).map((_, i) => ({
  cx: 1140 + rnd() * 220,
  cy: 100 + rnd() * 600,
  r: 1 + rnd() * 1.8,
  delay: rnd() * 4,
  dur: 3 + rnd() * 2,
  idx: i,
}));

// Every Nth node gets a connection line so the edges aren't overwhelming
const leftWired = leftNodes.filter((_, i) => i % 3 === 0);
const rightWired = rightNodes.filter((_, i) => i % 3 === 0);

// "Emitter" nodes — a subset that shoots off expanding ping rings at
// staggered intervals. Keep the count modest so the scene stays calm.
const emitters = [
  ...leftNodes.filter((_, i) => i % 2 === 0),
  ...rightNodes.filter((_, i) => i % 2 === 1),
].map((n, i) => ({
  ...n,
  // Each emitter pulses on a ~5s cycle, evenly staggered across the pool so
  // at any given moment ~1 in 5 nodes is mid-ping.
  pingDelay: (i * 0.55) % 5,
  pingDur: 4 + rnd() * 1.5,
}));

// Deterministic pairing so each left-wired node connects to exactly one
// right-wired node. Arcs curve gently through the middle of the canvas,
// implying flow without needing a visible hub.
const pairs: Array<{
  x1: number;
  y1: number;
  x2: number;
  y2: number;
  delay: number;
}> = [];
for (let i = 0; i < Math.max(leftWired.length, rightWired.length); i++) {
  const a = leftWired[i % leftWired.length]!;
  const b = rightWired[i % rightWired.length]!;
  pairs.push({
    x1: a.cx,
    y1: a.cy,
    x2: b.cx,
    y2: b.cy,
    delay: i * 0.4,
  });
}

function arc(x1: number, y1: number, x2: number, y2: number) {
  // Two control points so the curve has a gentle S-ish sweep rather than
  // pointing at a specific hub.
  const c1x = x1 + (x2 - x1) * 0.35;
  const c1y = y1 + (y2 - y1) * 0.15 + (y1 < 400 ? -30 : 30);
  const c2x = x1 + (x2 - x1) * 0.65;
  const c2y = y1 + (y2 - y1) * 0.85 + (y2 < 400 ? -30 : 30);
  return `M ${x1} ${y1} C ${c1x} ${c1y} ${c2x} ${c2y} ${x2} ${y2}`;
}
---

<div
  aria-hidden="true"
  class="pointer-events-none absolute inset-x-0 top-0 -z-20 overflow-hidden mission-graph"
>
  <svg
    viewBox="0 0 1440 800"
    preserveAspectRatio="xMidYMin slice"
    class="w-full h-full"
    role="presentation"
  >
    <defs>
      <linearGradient id="mg-edge" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#818cf8" stop-opacity="0" />
        <stop offset="50%" stop-color="#818cf8" stop-opacity="0.55" />
        <stop offset="100%" stop-color="#8b5cf6" stop-opacity="0" />
      </linearGradient>
      <radialGradient id="mg-node" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#c7d2fe" stop-opacity="0.9" />
        <stop offset="100%" stop-color="#818cf8" stop-opacity="0" />
      </radialGradient>
      <filter id="mg-blur" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="0.4" />
      </filter>
    </defs>

    {/* Connection arcs from left cluster → right spray */}
    <g class="mg-edges" filter="url(#mg-blur)">
      {
        pairs.map((p) => (
          <path
            d={arc(p.x1, p.y1, p.x2, p.y2)}
            stroke="url(#mg-edge)"
            stroke-width="0.9"
            fill="none"
            stroke-dasharray="3 7"
            style={`animation-delay: ${p.delay.toFixed(2)}s`}
          />
        ))
      }
    </g>

    {/* Left cluster nodes */}
    <g class="mg-nodes">
      {
        leftNodes.map((n) => (
          <circle
            cx={n.cx}
            cy={n.cy}
            r={n.r}
            fill="url(#mg-node)"
            style={`--d:${n.dur}s; --t:${n.delay}s;`}
          />
        ))
      }
    </g>

    {/* Right spray nodes */}
    <g class="mg-nodes">
      {
        rightNodes.map((n) => (
          <circle
            cx={n.cx}
            cy={n.cy}
            r={n.r}
            fill="url(#mg-node)"
            style={`--d:${n.dur}s; --t:${n.delay}s;`}
          />
        ))
      }
    </g>

    {/* Ping rings — circle-explosions emitted from select nodes */}
    <g class="mg-pings" stroke="#818cf8" fill="none">
      {
        emitters.map((n) => (
          <circle
            cx={n.cx}
            cy={n.cy}
            r={n.r + 0.5}
            stroke-width="0.8"
            style={`transform-origin: ${n.cx}px ${n.cy}px; animation-delay: ${n.pingDelay.toFixed(2)}s; animation-duration: ${n.pingDur.toFixed(2)}s;`}
          />
        ))
      }
      {/* A second ring per emitter, offset in time for a richer rhythm */}
      {
        emitters.map((n) => (
          <circle
            cx={n.cx}
            cy={n.cy}
            r={n.r + 0.5}
            stroke-width="0.8"
            style={`transform-origin: ${n.cx}px ${n.cy}px; animation-delay: ${(n.pingDelay + n.pingDur / 2).toFixed(2)}s; animation-duration: ${n.pingDur.toFixed(2)}s;`}
          />
        ))
      }
    </g>
  </svg>
</div>

<style>
  .mission-graph {
    /* Anchored at the top of the page; fades out as the user scrolls past
       the hero region so it never competes with content below. */
    height: 100vh;
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0,
      #000 6%,
      #000 60%,
      transparent 100%
    );
            mask-image: linear-gradient(
      to bottom,
      transparent 0,
      #000 6%,
      #000 60%,
      transparent 100%
    );
    opacity: 0.55;
  }

  /* Edges: dashes flow from left to right, continuously */
  .mg-edges path {
    animation: mg-flow 4s linear infinite;
  }
  @keyframes mg-flow {
    to {
      stroke-dashoffset: -40;
    }
  }

  /* Nodes: gentle twinkle, randomized via inline --d / --t */
  .mg-nodes circle {
    animation: mg-twinkle var(--d, 4s) ease-in-out infinite;
    animation-delay: var(--t, 0s);
    transform-origin: center;
    transform-box: fill-box;
  }
  @keyframes mg-twinkle {
    0%,
    100% {
      opacity: 0.25;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.6);
    }
  }

  /* Ping rings: scale out from the emitter and fade. Each ring runs on the
     inline --duration set by the template; we just define the keyframes. */
  .mg-pings circle {
    animation-name: mg-ping;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    animation-iteration-count: infinite;
    stroke-opacity: 0;
  }
  @keyframes mg-ping {
    0% {
      transform: scale(1);
      stroke-opacity: 0.7;
      stroke-width: 1.2;
    }
    70% {
      stroke-opacity: 0.15;
    }
    100% {
      transform: scale(10);
      stroke-opacity: 0;
      stroke-width: 0.4;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mg-edges path,
    .mg-nodes circle,
    .mg-pings circle {
      animation: none !important;
    }
    .mg-pings circle {
      display: none;
    }
    .mission-graph {
      opacity: 0.35;
    }
  }
</style>
