---
export interface Props {
  title: string;
  class?: string;
  revealIndex?: number;
}
const { title, class: cls = "", revealIndex = 0 } = Astro.props;
---

<article
  data-reveal
  style={`--reveal-delay: ${revealIndex}`}
  class:list={[
    "pi-gradient-border pi-hover-glow rounded-2xl bg-pi-surface/60 p-8 backdrop-blur-sm",
    "flex flex-col gap-5",
    cls,
  ]}
>
  <div class="flex items-center gap-4">
    <div
      class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-pi-accent/25 to-pi-accent2/15 border border-pi-accent/30"
    >
      <slot name="icon" />
    </div>
    <h3 class="text-xl font-semibold tracking-tight text-pi-fg">
      {title}
    </h3>
  </div>
  <div class="text-base leading-relaxed text-pi-muted">
    <slot />
  </div>
  <div class="mt-auto pt-2">
    <slot name="visual" />
  </div>
</article>
