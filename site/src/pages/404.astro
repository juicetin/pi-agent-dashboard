---
import Base from "~/layouts/Base.astro";
---

<Base title="404 — this session was aborted" description="The page you were looking for is not here.">
  <section class="relative min-h-[calc(100vh-3.5rem)] flex items-center justify-center px-4">
    <div class="w-full max-w-2xl">
      <div class="pi-gradient-border rounded-xl bg-pi-bg/80 backdrop-blur font-mono text-sm overflow-hidden shadow-pi-glow">
        <div class="flex items-center gap-2 h-9 px-4 border-b border-pi-border/60 bg-pi-surface/80">
          <span class="h-2.5 w-2.5 rounded-full bg-red-400/80"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-amber-400/80"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-emerald-400/80"></span>
          <span class="flex-1 text-center text-xs text-pi-muted">~/pi-dashboard/sessions/404</span>
        </div>
        <div class="p-6 leading-relaxed text-pi-fg/80">
          <p><span class="text-pi-muted">&gt;</span> navigate <span class="text-pi-fg">{ Astro.url.pathname }</span></p>
          <p class="mt-2 text-red-300">✗ session_end &nbsp;<span class="text-pi-muted">(reason: route_not_found)</span></p>
          <p class="mt-2 text-pi-muted"># the page you were looking for is not here.</p>
          <p class="mt-2 text-pi-muted"># it may have been renamed, moved, or never existed.</p>

          <div class="mt-6 flex flex-col sm:flex-row gap-3">
            <a
              href="/pi-agent-dashboard/"
              class="inline-flex items-center justify-center gap-2 rounded-lg bg-gradient-to-r from-pi-accent to-pi-accent2 px-4 py-2 text-sm font-semibold text-pi-bg shadow-pi-glow hover:brightness-110 transition-all"
            >
              ← Return to dashboard
            </a>
            <a
              href="https://github.com/BlackBeltTechnology/pi-agent-dashboard/issues"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center gap-2 rounded-lg border border-pi-border/80 bg-pi-surface/60 px-4 py-2 text-sm text-pi-fg hover:border-pi-accent/60"
            >
              Report a broken link
            </a>
          </div>
        </div>
      </div>
      <p class="mt-6 text-center text-xs text-pi-muted">
        pi-dashboard · 404
      </p>
    </div>
  </section>
</Base>
